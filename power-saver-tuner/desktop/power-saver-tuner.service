[Unit]
Description=Power Saver CPU Tuner for power-profiles-daemon
Requires=power-profiles-daemon.service
After=power-profiles-daemon.service

[Service]
Type=simple
ExecStart=/usr/local/bin/power-saver-tuner.py
Restart=always
RestartSec=5

# Hardening
ProtectHome=yes
ProtectSystem=strict
ReadWritePaths=/sys

[Install]
WantedBy=graphical.target

